#!/usr/bin/env bash
# certmgr - Declarative DNS and TLS certificate manager
#
# DESCRIPTION:
#   Reconciles DNS records and TLS certificates against a YAML config file.
#   DNS is managed via RFC 2136 dynamic updates (nsupdate) authenticated with
#   a TSIG key. Certificates are issued and renewed via Let's Encrypt using
#   lego with DNS-01 challenges.
#
#   This script runs as a normal user. It requires the WireGuard tunnel to
#   the DNS server to already be up. Use certmgr-wg to manage the tunnel
#   automatically (e.g. from cron).
#
# USAGE:
#   certmgr [OPTIONS]
#
# OPTIONS:
#   -c, --config FILE   Path to config file (default: ~/.config/certmgr/config.yaml)
#   -n, --dry-run       Print planned changes without applying them
#   -q, --quiet         Suppress informational output
#   -v, --verbose       Show detailed operation output
#   -h, --help          Show this help message
#
# DEPENDENCIES:
#   - yq        (https://github.com/mikefarah/yq) for YAML parsing
#   - lego      (https://github.com/go-acme/lego) for certificate management
#   - nsupdate  (bind9utils package) for DNS updates
#   - dig       (dnsutils package) for AXFR zone transfers
#   - openssl   for certificate expiry checks
#
# CONFIGURATION:
#   See config.yaml for the configuration file format.
#
# CRON EXAMPLE (via certmgr-wg):
#   0 3 * * 1  /usr/local/bin/certmgr-wg
#
set -euo pipefail

# --- defaults ---
CONFIG_FILE="${HOME}/.config/certmgr/config.yaml"
DRY_RUN=0
QUIET=0
VERBOSE=0

# --- colours ---
if [[ -t 2 ]]; then
    C_INFO='\033[0;32m'
    C_WARN='\033[0;33m'
    C_ERR='\033[0;31m'
    C_RESET='\033[0m'
else
    C_INFO='' C_WARN='' C_ERR='' C_RESET=''
fi

log()     { [[ $QUIET -eq 0 ]] && echo -e "${C_INFO}[INFO]${C_RESET}  $*" >&2 || true; }
verbose() { [[ $VERBOSE -eq 1 ]] && echo -e "[DEBUG] $*" >&2 || true; }
warn()    { echo -e "${C_WARN}[WARN]${C_RESET}  $*" >&2; }
err()     { echo -e "${C_ERR}[ERROR]${C_RESET} $*" >&2; exit 1; }
dry()     { echo -e "[DRY-RUN] $*" >&2; }

# --- usage ---
usage() {
    sed -n '/^# DESCRIPTION:/,/^[^#]/{ /^#/{ s/^# \{0,1\}//; p } }' "$0"
    exit 0
}

# --- argument parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--config)  CONFIG_FILE="$2"; shift 2 ;;
        -n|--dry-run) DRY_RUN=1; shift ;;
        -q|--quiet)   QUIET=1; shift ;;
        -v|--verbose) VERBOSE=1; shift ;;
        -h|--help)    usage ;;
        *) err "Unknown option: $1" ;;
    esac
done

# --- dependency checks ---
for cmd in yq lego nsupdate dig openssl; do
    command -v "$cmd" >/dev/null 2>&1 || err "Required command not found: $cmd"
done

# --- load config ---
[[ -f "$CONFIG_FILE" ]] || err "Config file not found: $CONFIG_FILE"

cfg() { yq e "$1" "$CONFIG_FILE"; }

EMAIL=$(cfg '.email')
DNS_SERVER=$(cfg '.dns.server')
DNS_ZONE=$(cfg '.dns.zone')
TSIG_KEY_FILE=$(cfg '.dns.tsig_key_file')
TSIG_KEY_FILE="${TSIG_KEY_FILE/#\~/$HOME}"
LEGO_PATH=$(cfg '.lego.path')
LEGO_PATH="${LEGO_PATH/#\~/$HOME}"
CERT_RENEW_DAYS=$(cfg '.lego.renew_days // 30')

: "${EMAIL:?'email' is required in config}"
: "${DNS_SERVER:?'dns.server' is required in config}"
: "${DNS_ZONE:?'dns.zone' is required in config}"
: "${TSIG_KEY_FILE:?'dns.tsig_key_file' is required in config}"
: "${LEGO_PATH:?'lego.path' is required in config}"

[[ -f "$TSIG_KEY_FILE" ]] || err "TSIG key file not found: $TSIG_KEY_FILE"

# Ensure trailing dot on zone name
[[ "$DNS_ZONE" == *. ]] || DNS_ZONE="${DNS_ZONE}."

# --- validate config ---
validate_config() {
    log "Validating config..."
    local domain types
    while IFS= read -r domain; do
        types=$(yq e ".domains[] | select(.domain == \"$domain\") | .rr[][0]" "$CONFIG_FILE" 2>/dev/null || true)
        if echo "$types" | grep -q "^CNAME$" && \
           echo "$types" | grep -qv "^CNAME$"; then
            err "Domain '$domain' has CNAME mixed with other record types"
        fi
    done < <(cfg '.domains[].domain')
}

# --- normalise a DNS name to fully qualified ---
fqdn() {
    local name="$1"
    [[ "$name" == *. ]] && echo "$name" || echo "${name}."
}

# --- perform an nsupdate, or print if dry-run ---
nsupdate_run() {
    local commands="$1"
    if [[ $DRY_RUN -eq 1 ]]; then
        while IFS= read -r line; do
            dry "nsupdate: $line"
        done <<< "$commands"
        return
    fi
    verbose "nsupdate commands: $commands"
    nsupdate -k "$TSIG_KEY_FILE" <<< "$commands"
}

# =============================================================================
# DNS RECONCILIATION
# =============================================================================

# Fetch current zone records via AXFR.
# Outputs lines of the form: <fqdn> <type> <rdata...>
# Filters to only A, MX, CNAME records; skips SOA/NS/TXT.
axfr_fetch() {
    verbose "Fetching zone via AXFR from $DNS_SERVER"
    dig @"$DNS_SERVER" -k "$TSIG_KEY_FILE" "$DNS_ZONE" AXFR \
        | awk '
            /^;/ { next }
            $4 == "A"     { print $1, $4, $5 }
            $4 == "MX"    { print $1, $4, $5, $6 }
            $4 == "CNAME" { print $1, $4, $5 }
        '
}

# Parse desired records from config.
# Outputs lines in the same form as axfr_fetch.
config_records() {
    local domain fqdn_domain rr_count rr_type
    local domain_count
    domain_count=$(yq e '.domains | length' "$CONFIG_FILE")

    for (( i=0; i<domain_count; i++ )); do
        domain=$(yq e ".domains[$i].domain" "$CONFIG_FILE")
        fqdn_domain=$(fqdn "$domain")
        rr_count=$(yq e ".domains[$i].rr | length" "$CONFIG_FILE")

        local mx_priority=10
        for (( j=0; j<rr_count; j++ )); do
            rr_type=$(yq e ".domains[$i].rr[$j][0]" "$CONFIG_FILE")
            case "$rr_type" in
                A)
                    local ip
                    ip=$(yq e ".domains[$i].rr[$j][1]" "$CONFIG_FILE")
                    echo "$fqdn_domain A $ip"
                    ;;
                CNAME)
                    local target
                    target=$(yq e ".domains[$i].rr[$j][1]" "$CONFIG_FILE")
                    target=$(fqdn "$target")
                    echo "$fqdn_domain CNAME $target"
                    ;;
                MX)
                    local mx_count mx_val
                    mx_count=$(yq e ".domains[$i].rr[$j] | length - 1" "$CONFIG_FILE")
                    for (( k=0; k<mx_count; k++ )); do
                        mx_val=$(yq e ".domains[$i].rr[$j][$((k+1))]" "$CONFIG_FILE")
                        mx_val=$(fqdn "$mx_val")
                        echo "$fqdn_domain MX $mx_priority $mx_val"
                        (( mx_priority += 10 ))
                    done
                    ;;
            esac
        done
    done
}

reconcile_dns() {
    log "Reconciling DNS records..."

    local current desired

    # Read current and desired into associative arrays keyed by "<fqdn> <type> <rdata>"
    declare -A current_records desired_records

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        current_records["$line"]=1
        verbose "Current: $line"
    done < <(axfr_fetch)

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        desired_records["$line"]=1
        verbose "Desired: $line"
    done < <(config_records)

    # Records to add: in desired but not in current
    local adds=() deletes=()

    for record in "${!desired_records[@]}"; do
        if [[ -z "${current_records[$record]+x}" ]]; then
            adds+=("$record")
        fi
    done

    # Records to delete: in current but not in desired
    for record in "${!current_records[@]}"; do
        if [[ -z "${desired_records[$record]+x}" ]]; then
            deletes+=("$record")
        fi
    done

    if [[ ${#adds[@]} -eq 0 && ${#deletes[@]} -eq 0 ]]; then
        log "DNS records are up to date"
        return
    fi

    # Build a single nsupdate transaction
    local cmds
    cmds="server ${DNS_SERVER}
zone ${DNS_ZONE}"

    for record in "${deletes[@]}"; do
        read -r name type rdata <<< "$record"
        log "DNS delete: $name $type $rdata"
        cmds+="
update delete $name $type $rdata"
    done

    for record in "${adds[@]}"; do
        read -r name type rdata <<< "$record"
        log "DNS add: $name $type $rdata"
        cmds+="
update add $name 3600 $type $rdata"
    done

    cmds+="
send"

    nsupdate_run "$cmds"
    log "DNS reconciliation complete"
}

# =============================================================================
# CERTIFICATE RECONCILIATION
# =============================================================================

cert_days_remaining() {
    local domain="$1"
    local cert_file="$LEGO_PATH/certificates/${domain}.crt"
    [[ -f "$cert_file" ]] || { echo -1; return; }
    local expiry_epoch now_epoch
    expiry_epoch=$(date -d "$(openssl x509 -enddate -noout -in "$cert_file" \
        | cut -d= -f2)" +%s 2>/dev/null) || { echo -1; return; }
    now_epoch=$(date +%s)
    echo $(( (expiry_epoch - now_epoch) / 86400 ))
}

lego_run() {
    local args=("$@")
    if [[ $DRY_RUN -eq 1 ]]; then
        dry "lego ${args[*]}"
        return
    fi
    if [[ $VERBOSE -eq 1 ]]; then
        lego "${args[@]}"
    else
        lego "${args[@]}" 2>&1 | grep -v "^\[DEBUG\]" || true
    fi
}

reconcile_certs() {
    log "Reconciling certificates..."

    local domain_count
    domain_count=$(yq e '.domains | length' "$CONFIG_FILE")

    local cert_domains=()

    for (( i=0; i<domain_count; i++ )); do
        local domain want_cert
        domain=$(yq e ".domains[$i].domain" "$CONFIG_FILE")
        want_cert=$(yq e ".domains[$i].cert // false" "$CONFIG_FILE")

        [[ "$want_cert" == "true" ]] || continue
        cert_domains+=("$domain")

        local days
        days=$(cert_days_remaining "$domain")

        if [[ $days -lt 0 ]]; then
            log "Issuing new certificate for $domain"
            lego_run \
                --email "$EMAIL" \
                --dns rfc2136 \
                --path "$LEGO_PATH" \
                --domains "$domain" \
                --accept-tos \
                run \
                --run-hook "$(dirname "$0")/acme-auth.sh"
        elif [[ $days -le $CERT_RENEW_DAYS ]]; then
            log "Renewing certificate for $domain ($days days remaining)"
            lego_run \
                --email "$EMAIL" \
                --dns rfc2136 \
                --path "$LEGO_PATH" \
                --domains "$domain" \
                renew \
                --days "$CERT_RENEW_DAYS" \
                --renew-hook "$(dirname "$0")/acme-auth.sh"
        else
            log "Certificate for $domain is valid ($days days remaining)"
        fi
    done

    # Warn about cert files on disk not in config
    if [[ -d "$LEGO_PATH/certificates" ]]; then
        for cert_file in "$LEGO_PATH/certificates/"*.crt; do
            [[ -f "$cert_file" ]] || continue
            local on_disk
            on_disk=$(basename "$cert_file" .crt)
            local found=0
            for d in "${cert_domains[@]+"${cert_domains[@]}"}"; do
                [[ "$d" == "$on_disk" ]] && found=1 && break
            done
            if [[ $found -eq 0 ]]; then
                warn "Certificate on disk not in config: $on_disk"
            fi
        done
    fi
}

# =============================================================================
# MAIN
# =============================================================================

validate_config
reconcile_dns
reconcile_certs

log "Done"
