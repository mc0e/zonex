#!/usr/bin/env bash
# certmgr-wg - WireGuard tunnel wrapper for certmgr
#
# DESCRIPTION:
#   Brings up a WireGuard tunnel, runs certmgr as the unprivileged user who
#   owns the config, then tears down the tunnel. Designed to be run as root
#   (e.g. via cron or sudo) so that wg-quick can manage the tunnel without
#   requiring the user to have persistent elevated privileges.
#
# USAGE:
#   certmgr-wg [OPTIONS]
#
# OPTIONS:
#   -c, --config FILE   Path to certmgr config file
#                       (default: ~/.config/certmgr/config.yaml, resolved
#                       relative to SUDO_USER's home if run via sudo)
#   -u, --user USER     Run certmgr as USER (default: $SUDO_USER or $USER)
#   -h, --help          Show this help message
#
#   Additional options are passed through to certmgr (e.g. --dry-run,
#   --quiet, --verbose).
#
# CRON EXAMPLE (in root's crontab, or via sudo):
#   0 3 * * 1  /usr/local/bin/certmgr-wg --quiet
#
# SUDOERS EXAMPLE (to allow a user to run this without a password):
#   username ALL=(root) NOPASSWD: /usr/local/bin/certmgr-wg
#
# DEPENDENCIES:
#   - wg-quick  (wireguard-tools package)
#   - certmgr   (must be on PATH)
#   - yq        (https://github.com/mikefarah/yq)
#
set -euo pipefail

# --- colours ---
if [[ -t 2 ]]; then
    C_INFO='\033[0;32m'
    C_WARN='\033[0;33m'
    C_ERR='\033[0;31m'
    C_RESET='\033[0m'
else
    C_INFO='' C_WARN='' C_ERR='' C_RESET=''
fi

log()  { echo -e "${C_INFO}[INFO]${C_RESET}  $*" >&2; }
warn() { echo -e "${C_WARN}[WARN]${C_RESET}  $*" >&2; }
err()  { echo -e "${C_ERR}[ERROR]${C_RESET} $*" >&2; exit 1; }

usage() {
    sed -n '/^# DESCRIPTION:/,/^[^#]/{ /^#/{ s/^# \{0,1\}//; p } }' "$0"
    exit 0
}

# --- root check ---
if [[ $EUID -ne 0 ]]; then
    echo "certmgr-wg must be run as root (it manages WireGuard tunnels)." >&2
    echo "Try: sudo certmgr-wg $*" >&2
    exit 1
fi

# --- resolve unprivileged user ---
RUN_AS="${SUDO_USER:-}"
CONFIG_FILE=""
PASSTHROUGH_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)   RUN_AS="$2"; shift 2 ;;
        -c|--config) CONFIG_FILE="$2"; shift 2 ;;
        -h|--help)   usage ;;
        *)           PASSTHROUGH_ARGS+=("$1"); shift ;;
    esac
done

if [[ -z "$RUN_AS" ]]; then
    err "Cannot determine which user to run certmgr as. Use --user or run via sudo."
fi

if [[ "$RUN_AS" == "root" ]]; then
    err "Refusing to run certmgr as root. Use --user to specify an unprivileged user."
fi

# Resolve user's home directory
USER_HOME=$(getent passwd "$RUN_AS" | cut -d: -f6) \
    || err "User not found: $RUN_AS"

if [[ -z "$CONFIG_FILE" ]]; then
    CONFIG_FILE="${USER_HOME}/.config/certmgr/config.yaml"
fi

[[ -f "$CONFIG_FILE" ]] || err "Config file not found: $CONFIG_FILE"

# --- read WireGuard config path ---
WG_CONFIG=$(yq e '.wireguard.config' "$CONFIG_FILE") \
    || err "Could not read wireguard.config from $CONFIG_FILE"
WG_CONFIG="${WG_CONFIG/#\~/$USER_HOME}"

[[ -f "$WG_CONFIG" ]] || err "WireGuard config not found: $WG_CONFIG"

# Derive interface name from config filename (wg-quick convention)
WG_IFACE=$(basename "$WG_CONFIG" .conf)

# --- WireGuard tunnel lifecycle ---
log "Bringing up WireGuard interface $WG_IFACE (for DNS access)"
if ! wg-quick up "$WG_CONFIG" 2>&1; then
    err "Failed to bring up WireGuard interface $WG_IFACE"
fi

teardown() {
    log "Tearing down WireGuard interface $WG_IFACE"
    wg-quick down "$WG_CONFIG" >/dev/null 2>&1 || \
        warn "Failed to bring down $WG_IFACE — may need manual cleanup"
}
trap teardown EXIT

# --- run certmgr as unprivileged user ---
log "Running certmgr as $RUN_AS"

CERTMGR_ARGS=(--config "$CONFIG_FILE")
CERTMGR_ARGS+=("${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}")

sudo -u "$RUN_AS" certmgr "${CERTMGR_ARGS[@]}"
